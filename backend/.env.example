# ═══════════════════════════════════════════════════════════════
# Multi-LLM 토론 시스템 환경변수 설정
# ═══════════════════════════════════════════════════════════════

# ── [방식 A] Direct API (기본값) ─────────────────────────────
# EXPERT1/2/3_PROVIDER를 비워 두면 아래 키로 Claude/GPT/Gemini 직접 연결
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=your-google-api-key

# Expert 모델 (direct API 방식)
CLAUDE_MODEL=claude-sonnet-4-6
GPT_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash

# ── [방식 B] OpenRouter (단일 키로 100+ 모델 선택) ────────────
# https://openrouter.ai 에서 API 키 발급
OPENROUTER_API_KEY=your-openrouter-api-key

# 예: OpenRouter로 세 전문가 모두 교체
# EXPERT1_PROVIDER=openrouter
# EXPERT1_MODEL=anthropic/claude-3.5-sonnet
# EXPERT1_API_KEY=    # 비워두면 OPENROUTER_API_KEY 사용
#
# EXPERT2_PROVIDER=openrouter
# EXPERT2_MODEL=openai/gpt-4o
#
# EXPERT3_PROVIDER=openrouter
# EXPERT3_MODEL=google/gemini-pro-1.5

# ── [방식 C] Kilo Gateway (kilo.ai) ──────────────────────────
# https://app.kilo.ai 에서 API 키 발급 (500+ 모델 단일 엔드포인트)
# base_url: https://api.kilo.ai/api/gateway (자동 설정됨, 지정 불필요)
# 모델 이름 형식: anthropic/claude-sonnet-4-5, openai/gpt-4o 등
#
# KILO_API_KEY를 설정하면 EXPERT{n}_API_KEY 없이도 자동으로 사용됨
KILO_API_KEY=your-kilo-api-key

# ┌ Kilo 단일 키로 Claude + GPT + Gemini 세 전문가 설정 예시 ┐
# EXPERT1_PROVIDER=kilo
# EXPERT1_MODEL=anthropic/claude-sonnet-4-5
#
# EXPERT2_PROVIDER=kilo
# EXPERT2_MODEL=openai/gpt-4o
#
# EXPERT3_PROVIDER=kilo
# EXPERT3_MODEL=google/gemini-pro-1.5
# └─────────────────────────────────────────────────────────┘

# ── [방식 D] Ollama (로컬 모델) ───────────────────────────────
# ollama pull llama3.3 후 아래와 같이 설정
#
# EXPERT1_PROVIDER=ollama
# EXPERT1_MODEL=llama3.3
# EXPERT1_API_KEY=ollama        # 임의값 (Ollama는 키 불필요)
# EXPERT1_BASE_URL=              # 비워두면 http://localhost:11434/v1 사용

# ── [방식 E] 임의 OpenAI 호환 서버 ───────────────────────────
# LM Studio, vLLM, Together AI, Groq 등
#
# EXPERT1_PROVIDER=custom
# EXPERT1_MODEL=<모델명>
# EXPERT1_API_KEY=<api-key>
# EXPERT1_BASE_URL=<base-url>   # 예: https://api.groq.com/openai/v1
# EXPERT1_NAME=내 로컬 LLM      # 표시 이름 (선택)

# ── Judge ────────────────────────────────────────────────────
# judge_provider: anthropic | openai | google | openrouter | kilo
JUDGE_PROVIDER=anthropic
JUDGE_MODEL=claude-opus-4-7
# JUDGE_API_KEY=                # 비워두면 provider에 맞는 기본 키 사용
# JUDGE_BASE_URL=               # 범용 provider 사용 시 지정
#
# Kilo로 Judge 사용 예시:
# JUDGE_PROVIDER=kilo
# JUDGE_MODEL=anthropic/claude-opus-4-5   # Kilo 모델명 형식
# JUDGE_API_KEY=                           # 비워두면 KILO_API_KEY 사용

# ── Debate Settings ──────────────────────────────────────────
MAX_ROUNDS=3
MAX_TOKENS_PER_TURN=1500
SESSION_TOKEN_BUDGET=50000

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
